/ {
    combos {
        compatible = "zmk,combos";

        combo_boot_dual {
            timeout-ms = <90>;
            key-positions = <0 1 8>;
            bindings = <&bootloader>;
        };

        combo_enter {
            timeout-ms = <150>;
            key-positions = <6 7>;
            bindings = <&kp RET>;
            require-prior-idle-ms = <50>;
        };

        combo_esc {
            timeout-ms = <150>;
            key-positions = <4 5>;
            bindings = <&kp ESC>;
            require-prior-idle-ms = <50>;
        };
    };
};
